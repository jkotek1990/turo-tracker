{% extends "base.html" %}
{% block title %}Settings - Turo Tracker{% endblock %}
{% block content %}

<h2>Settings</h2>

<form method="POST" class="form">
  <label>IRS standard mileage rate ($/mile)
    <input type="number" step="0.001" min="0" name="mileage_rate" required value="{{ mileage_rate }}">
  </label>
  <p class="subtitle" style="margin:0;">
    Used to calculate the deduction for any "Mileage" expense you log. The IRS sets a new business rate most years,
    usually announced in December &mdash; check
    <a href="https://www.irs.gov/tax-professionals/standard-mileage-rates" target="_blank" rel="noopener">irs.gov/tax-professionals/standard-mileage-rates</a>
    and update the number here when it changes. The rate used on each past entry is locked in at the time you logged it,
    so updating this won't change old entries.
  </p>

  <label>Default oil change interval (miles)
    <input type="number" step="1" min="1" name="oil_change_interval_miles" required value="{{ oil_change_interval }}">
  </label>
  <p class="subtitle" style="margin:0;">
    Applies to any car that doesn't have its own custom interval set on its Edit Car page.
  </p>

  <div class="form-actions">
    <button type="submit" class="btn">Save</button>
    <a href="{{ url_for('dashboard') }}" class="btn btn-secondary">Cancel</a>
  </div>
</form>

{% endblock %}
