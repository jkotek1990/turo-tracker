{% extends "base.html" %}
{% block title %}{{ 'Edit' if txn else 'Add' }} Transaction - Turo Tracker{% endblock %}
{% block content %}

<h2>{{ 'Edit' if txn else 'Add' }} Transaction &mdash; {{ car.nickname }}</h2>

<form method="POST" class="form" id="txn-form">
  <label>Date *
    <input type="date" name="date" required value="{{ txn.date if txn else today }}">
  </label>

  <fieldset class="type-toggle">
    <legend>Type *</legend>
    <label class="radio">
      <input type="radio" name="type" value="income" {{ 'checked' if (txn and txn.type == 'income') or not txn }} onchange="updateCategories()">
      Income
    </label>
    <label class="radio">
      <input type="radio" name="type" value="expense" {{ 'checked' if txn and txn.type == 'expense' }} onchange="updateCategories()">
      Expense
    </label>
  </fieldset>

  <label>Category *
    <select name="category" id="category-select" required onchange="updateMileageUI()"></select>
  </label>

  <div id="miles-row" style="display:none;">
    <label>Miles driven (at ${{ '%.3f'|format(mileage_rate) }}/mi)
      <input type="number" step="0.1" min="0" id="miles-input" name="miles" value="{{ txn.miles if txn and txn.miles else '' }}" oninput="recomputeMileageAmount()">
    </label>
  </div>

  <p id="loan-hint" class="subtitle" style="display:none; margin:0;">
    Only the interest portion of a loan payment is tax-deductible. Enter just the interest here &mdash;
    log the principal portion separately as a <a href="{{ url_for('new_payback', car_id=car.id) }}" target="_blank" rel="noopener">Payback</a>
    so it reduces your payoff balance instead of (incorrectly) your Net Profit.
  </p>

  <label>Amount ($) *
    <input type="number" step="0.01" min="0" name="amount" id="amount-input" required value="{{ txn.amount if txn else '' }}">
  </label>

  <div id="paid-by-row">
    <label class="checkbox">
      <input type="checkbox" name="paid_by_company" {{ 'checked' if not txn or txn.paid_by_company }}>
      Paid directly from the company (uncheck if you need to be reimbursed)
    </label>
  </div>

  <label>Notes
    <textarea name="notes" rows="3" placeholder="Optional details">{{ txn.notes if txn else '' }}</textarea>
  </label>

  <div class="form-actions">
    <button type="submit" class="btn">{{ 'Save Changes' if txn else 'Add Transaction' }}</button>
    <a href="{{ url_for('car_detail', car_id=car.id) }}" class="btn btn-secondary">Cancel</a>
  </div>
</form>

<script>
  const incomeCategories = {{ categories_income|tojson }};
  const expenseCategories = {{ categories_expense|tojson }};
  const selectedCategory = {{ (txn.category if txn else '')|tojson }};
  const MILEAGE_RATE = {{ mileage_rate }};

  function updateCategories() {
    const type = document.querySelector('input[name="type"]:checked').value;
    const select = document.getElementById('category-select');
    const options = type === 'income' ? incomeCategories : expenseCategories;
    select.innerHTML = '';
    options.forEach(opt => {
      const el = document.createElement('option');
      el.value = opt;
      el.textContent = opt;
      if (opt === selectedCategory) el.selected = true;
      select.appendChild(el);
    });
    document.getElementById('paid-by-row').style.display = type === 'expense' ? 'block' : 'none';
    updateMileageUI();
  }

  function updateMileageUI() {
    const category = document.getElementById('category-select').value;
    const milesRow = document.getElementById('miles-row');
    const amountInput = document.getElementById('amount-input');
    if (category === 'Mileage') {
      milesRow.style.display = 'block';
      amountInput.readOnly = true;
      recomputeMileageAmount();
    } else {
      milesRow.style.display = 'none';
      amountInput.readOnly = false;
    }
    document.getElementById('loan-hint').style.display = category === 'Loan payment' ? 'block' : 'none';
  }

  function recomputeMileageAmount() {
    const miles = parseFloat(document.getElementById('miles-input').value) || 0;
    document.getElementById('amount-input').value = (miles * MILEAGE_RATE).toFixed(2);
  }

  updateCategories();
</script>

{% endblock %}
