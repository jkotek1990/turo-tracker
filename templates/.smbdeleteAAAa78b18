{% extends "base.html" %}
{% block title %}{{ 'Edit' if expense else 'Add' }} General Expense - Turo Tracker{% endblock %}
{% block content %}

<h2>{{ 'Edit' if expense else 'Add' }} General Expense</h2>
<p class="subtitle" style="margin-top:-4px;">
  For costs shared across your whole fleet (cleaning supplies, etc.) rather than one car.
</p>

<form method="POST" class="form">
  <label>Date *
    <input type="date" name="date" required value="{{ expense.date if expense else today }}">
  </label>

  <label>Category *
    <select name="category" id="category-select" required onchange="updateMileageUI()">
      {% for cat in categories_expense %}
        <option value="{{ cat }}" {{ 'selected' if expense and expense.category == cat }}>{{ cat }}</option>
      {% endfor %}
    </select>
  </label>

  <div id="miles-row" style="display:none;">
    <label>Miles driven (at ${{ '%.3f'|format(mileage_rate) }}/mi)
      <input type="number" step="0.1" min="0" id="miles-input" name="miles" value="{{ expense.miles if expense and expense.miles else '' }}" oninput="recomputeMileageAmount()">
    </label>
  </div>

  <p id="loan-hint" class="subtitle" style="display:none; margin:0;">
    Only the interest portion of a loan payment is tax-deductible. Enter just the interest here &mdash;
    log the principal portion separately as a Payback on that car's detail page, so it reduces the
    payoff balance instead of (incorrectly) your Net Profit.
  </p>

  <label>Amount ($) *
    <input type="number" step="0.01" min="0" name="amount" id="amount-input" required value="{{ expense.amount if expense else '' }}">
  </label>

  <label class="checkbox">
    <input type="checkbox" name="paid_by_company" {{ 'checked' if not expense or expense.paid_by_company }}>
    Paid directly from the company (uncheck if you need to be reimbursed)
  </label>

  <label>Notes
    <textarea name="notes" rows="3" placeholder="Optional details">{{ expense.notes if expense else '' }}</textarea>
  </label>

  <div class="form-actions">
    <button type="submit" class="btn">{{ 'Save Changes' if expense else 'Add Expense' }}</button>
    <a href="{{ url_for('general_expenses') }}" class="btn btn-secondary">Cancel</a>
  </div>
</form>

<script>
  const MILEAGE_RATE = {{ mileage_rate }};

  function updateMileageUI() {
    const category = document.getElementById('category-select').value;
    const milesRow = document.getElementById('miles-row');
    const amountInput = document.getElementById('amount-input');
    if (category === 'Mileage') {
      milesRow.style.display = 'block';
      amountInput.readOnly = true;
      recomputeMileageAmount();
    } else {
      milesRow.style.display = 'none';
      amountInput.readOnly = false;
    }
    document.getElementById('loan-hint').style.display = category === 'Loan payment' ? 'block' : 'none';
  }

  function recomputeMileageAmount() {
    const miles = parseFloat(document.getElementById('miles-input').value) || 0;
    document.getElementById('amount-input').value = (miles * MILEAGE_RATE).toFixed(2);
  }

  updateMileageUI();
</script>

{% endblock %}
