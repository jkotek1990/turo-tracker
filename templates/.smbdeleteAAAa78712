{% extends "base.html" %}
{% block title %}{{ 'Edit' if payback else 'Log' }} Payback - Turo Tracker{% endblock %}
{% block content %}

<h2>{{ 'Edit' if payback else 'Log' }} Payback &mdash; {{ car.nickname }}</h2>
<p class="subtitle" style="margin-top:-4px;">
  Repayment of {{ 'cash you fronted' if car.funding_type == 'cash' else 'the bank loan' }} for this car.
  This does not affect income/expense or net profit.
</p>

<form method="POST" class="form">
  <label>Date *
    <input type="date" name="date" required value="{{ payback.date if payback else today }}">
  </label>

  <label>Amount ($) *
    <input type="number" step="0.01" min="0" name="amount" required value="{{ payback.amount if payback else '' }}">
  </label>

  <label>Notes
    <textarea name="notes" rows="3" placeholder="Optional details">{{ payback.notes if payback else '' }}</textarea>
  </label>

  <div class="form-actions">
    <button type="submit" class="btn">{{ 'Save Changes' if payback else 'Log Payback' }}</button>
    <a href="{{ url_for('car_detail', car_id=car.id) }}" class="btn btn-secondary">Cancel</a>
  </div>
</form>

{% endblock %}
